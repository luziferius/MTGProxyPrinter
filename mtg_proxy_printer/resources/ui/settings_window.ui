     <widget class="QWidget" name="tab_card_data_download">
      <attribute name="title">
       <string>Card data download</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout">
       <item>
        <widget class="QLabel" name="card_download_settings_header_label">
         <property name="text">
          <string>Changing these options requires re-downloading the card data from Scryfall.</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QGroupBox" name="card_download_general_settings">
         <property name="title">
          <string>General download filters</string>
         </property>
         <layout class="QVBoxLayout" name="verticalLayout_4">
          <item>
           <widget class="QCheckBox" name="include_cards_depicting_racism">
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Enable downloading cards banned for depicting racism.&lt;/p&gt;&lt;p&gt;Changing this option only takes effect when re-building the program’s card database by completely omitting the cards or including them during the download process.&lt;/p&gt;&lt;p&gt;Background:&lt;/p&gt;&lt;p&gt;Some cards were banned by Wizards of the Coast, because they depict references to controversial real-world events, religion or contain combinations of card effect, name and artwork that, when viewed together, depict racism. These cards are banned in all sanctioned tournament formats and several community formats like Commander, Oathbreaker and others.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="text">
             <string>Include cards depicting racism</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="include_cards_without_images">
            <property name="toolTip">
             <string>Include non-English cards with low-resolution,
English placeholder images with an overlay text stating
“This card is not available in the selected language.”</string>
            </property>
            <property name="text">
             <string>Include cards with placholder images</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="include_white_bordered_cards">
            <property name="text">
             <string>Include white-bordered cards</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="include_gold_bordered_cards">
            <property name="toolTip">
             <string>Some “collectible” sets, like full reprints of tournament-winning decks were printed with golden borders.
These are not tournament legal.</string>
            </property>
            <property name="text">
             <string>Include gold-bordered cards</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="include_funny_cards">
            <property name="toolTip">
             <string>“Funny” cards, not legal in any constructed format. This includes full-art Contraptions from Unstable and some black-bordered promotional cards, in addition to all silver-bordered cards.</string>
            </property>
            <property name="text">
             <string>Include “funny” cards</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="include_token">
            <property name="text">
             <string>Include Token cards</string>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <widget class="QGroupBox" name="card_download_format_settings">
         <property name="title">
          <string>Include cards banned in specific Formats</string>
         </property>
         <layout class="QGridLayout" name="gridLayout_3">
          <item row="0" column="0">
           <widget class="QCheckBox" name="include_banned_in_brawl">
            <property name="text">
             <string>Brawl</string>
            </property>
           </widget>
